# Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=8080

# MySQL (Local)
MYSQL_URL=jdbc:mysql://localhost:3306/certifypro?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
MYSQL_USER=root
MYSQL_PASSWORD=

# JWT
JWT_SECRET=certifypro-super-secret-key-change-this-in-production-2024
JWT_EXPIRATION=604800000

# File Upload
FILE_UPLOAD_DIR=uploads

# Email (set EMAIL_MOCK=false and fill credentials for real emails)
EMAIL_MOCK=true
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=CertifyPro <your@gmail.com>

# Admin Seed Account
ADMIN_EMAIL=admin@certify.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=System Admin
ADMIN_SEED_ENABLED=false

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
